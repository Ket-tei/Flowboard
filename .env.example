# === Database ===
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=flowboard
MYSQL_USER=flowboard
MYSQL_PASSWORD=flowboard

# === API (local dev — copy to apps/api/.env) ===
DATABASE_URL=mysql://flowboard:flowboard@localhost:3306/flowboard

# REQUIRED: Use a long random string (min 64 chars) — never commit the real value
JWT_SECRET=change-me-in-production-use-long-random-string

# REQUIRED: Admin bootstrap credentials (used only on first run when DB is empty)
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-use-strong-password

UPLOAD_DIR=./data/uploads
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
PORT=3001
NODE_ENV=development

# === Web (Vite) ===
VITE_API_URL=http://localhost:3001
